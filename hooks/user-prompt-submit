#!/usr/bin/env bash
# plume-skills UserPromptSubmit hook
# Injects DIGEST_ROOT into conversation context.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DIGEST_ROOT="$(dirname "$SCRIPT_DIR")"

ESCAPED="[DIGEST_ROOT: $DIGEST_ROOT]"

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "$ESCAPED"
  }
}
EOF
